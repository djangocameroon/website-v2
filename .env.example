# Base URL of the Django API (public — used by the browser bundle and next/image config)
NEXT_PUBLIC_API_URL='http://localhost:8912'
# Optional server-only override (falls back to NEXT_PUBLIC_API_URL)
API_URL='http://localhost:8912'
NEXT_PUBLIC_DJANGO_COMMUNITY_INVITE_LINK=the-link-to-the-django-community
# Public site URL used for canonical/sitemap generation
SITE_URL='https://djangocameroon.org'

# Optional: YouTube API key for fetching video data (used by the YouTube component)
YOUTUBE_API_KEY=your-youtube-api-key
